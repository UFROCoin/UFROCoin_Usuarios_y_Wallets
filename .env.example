MONGODB_URL=<your_mongodb_connection_string>
MONGODB_DB_NAME=ufrocoin_modulo_a
SECRET_KEY=<your_secret_key>
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
GENESIS_SENDER=SYSTEM_REWARD
INITIAL_WALLET_BALANCE=100.0

# Configuración de Resend para recuperación de contraseñas
RESEND_API_KEY=<your_resend_api_key>
RESEND_FROM_EMAIL="UFROCoin <no-reply@ufrocoin.email>"
RESEND_RESET_SUBJECT=Recuperacion de contrasena UFROCoin
PASSWORD_RESET_BASE_URL=https://app.ufrocoin.cl/reset-password
RESEND_TIMEOUT_SECONDS=10